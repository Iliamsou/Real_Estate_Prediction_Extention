{
  "manifest_version": 3,
  "name": "Estimation Immobilière",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.leboncoin.fr/ad/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
